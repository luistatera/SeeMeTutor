# SeeMe Tutor — Environment Variables
# =====================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is listed in .gitignore.
#
# Local development:
#   cp .env.example .env
#   # Edit .env with your real values
#   cd backend && uvicorn main:app --reload --port 8000
#
# Production (Cloud Run):


# ---------------------------------------------------------------------------
# Google Cloud Project
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=seeme-tutor
GCP_REGION=europe-west1

# ---------------------------------------------------------------------------
# Firestore
# Collection used to store active session state and interaction metadata.
# ---------------------------------------------------------------------------
FIRESTORE_COLLECTION=sessions

# ---------------------------------------------------------------------------
# Local development overrides (optional)
# Uncomment and set if you need to point at a non-default Firestore emulator
# or use a service account key file instead of Application Default Credentials.
# ---------------------------------------------------------------------------
# FIRESTORE_EMULATOR_HOST=localhost:8080
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ---------------------------------------------------------------------------
# Optional: MCP Google Search enrichment for source cards (direct links)
# Requires a Google Custom Search API key + Search Engine ID (cx).
# ---------------------------------------------------------------------------
# MCP_SEARCH_ENABLED=1
# MCP_SEARCH_SERVER_COMMAND=npx
# MCP_SEARCH_SERVER_ARGS=-y @adenot/mcp-google-search
# GOOGLE_API_KEY=your-google-custom-search-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-programmable-search-engine-id
